# Zkopíruj na .env a uprav. Pro TrueNAS Apps UI vlož tyto hodnoty přímo do
# 'environment' v compose (UI .env nečte).

# Heslo k DB (změň!)
DB_PASSWORD=zmen-me
DB_ROOT_PASSWORD=zmen-me-root

# Volitelné: Ollama pro chytrou normalizaci ingrediencí
# OLLAMA_URL=http://172.24.1.111:11434
# OLLAMA_MODEL=qwen2.5:7b

# Volitelné: SearXNG pro vyhledávání receptů
# SEARXNG_URL=http://searxng:8080

# Volitelné: whitelist domén (čárkou)
# RECIPE_DOMAINS=recepty.cz,toprecepty.cz,apetitonline.cz
