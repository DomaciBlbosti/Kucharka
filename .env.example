# Zkopíruj na .env a uprav. Pro TrueNAS Apps UI vlož tyto hodnoty přímo do
# 'environment' v compose (UI .env nečte).

# Heslo k DB (změň!)
DB_PASSWORD=AiKucharkaDB
DB_ROOT_PASSWORD=AiKucharkaDBRoot

# Volitelné: Ollama pro chytrou normalizaci ingrediencí
OLLAMA_URL=http://172.24.1.111:11434
OLLAMA_MODEL=qwen3:14b

# Volitelné: SearXNG pro vyhledávání receptů
SEARXNG_URL=http://172.24.1.111:30053

# Volitelné: whitelist domén (čárkou)
# RECIPE_DOMAINS=recepty.cz,toprecepty.cz,apetitonline.cz
RECIPE_DOMAINS=recepty.cz,toprecepty.cz,apetitonline.cz,vareni.cz,ireceptar.cz,klasicke-recepty.cz,bestrecepty.cz,kucharky.cz,dobruchut.cz,fresh.iprima.cz,recepty.eu,mimibazar.cz,allrecipes.com,bbcgoodfood.com,seriouseats.com,food.com,epicurious.com,simplyrecipes.com,budgetbytes.com,eatingwell.com,delish.com,tasteofhome.com,foodnetwork.com,thekitchn.com,bonappetit.com,kingarthurbaking.com,jamieoliver.com