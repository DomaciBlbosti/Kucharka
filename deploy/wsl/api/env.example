# Konfigurace API pro nativní běh ve WSL. Zkopíruje se do backend/.env.

# DB v distru kucharka-db (mirrored networking → localhost)
DATABASE_URL=mysql+pymysql://kucharka:kucharka@127.0.0.1:3306/kucharka?charset=utf8mb4

# CORS pro odlazení (frontend běží na jiném originu/portu)
CORS_ORIGINS=*

# Volitelné integrace (prázdné = vypnuto)
# Ollama běží na TrueNASu 172.24.1.111. Z WSL je to LAN adresa (funguje vždy,
# nezávisle na mirrored režimu). Model nastav na ten, který máš stažený
# (ověř: curl http://172.24.1.111:11434/api/tags).
OLLAMA_URL=http://172.24.1.111:11434
OLLAMA_MODEL=qwen3:8b
SEARXNG_URL=
RECIPE_DOMAINS=
SCRAPE_DELAY=1.0

# --- Autonomní crawler (sám plní DB) ---
# Plánovaný běh na pozadí (true = zapnuto). Tlačítko v UI funguje vždy.
CRAWLER_ENABLED=false
CRAWLER_INTERVAL_MIN=360
CRAWLER_MAX_PER_RUN=15
# Dorůstání surovin: chybějící surovinu doplní Ollama (odhad výživy)
AUTO_INGREDIENTS=true
# Vlastní seed dotazy (čárkou); prázdné = výchozí sada českých jídel
CRAWLER_SEEDS=
